        "tags": [
          "projects"
        ],
        "summary": "Insert one category into a project's list",
        "description": "Insert a new category at the given 0-based index (or at the end if `at_index` is omitted). The full project cache is cleared because a newly added category may better fit existing items; the service then triggers a re-sort.",
        "operationId": "add_category_projects__pid__categories_post",
        "parameters": [
          {
            "name": "pid",
            "in": "path",
            "required": true,
