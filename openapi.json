    "/projects/{pid}/sort": {
      "post": {
        "tags": [
          "projects"
        ],
        "summary": "Queue an immediate sort",
        "description": "Bypasses the debouncer and schedules a sort cycle for the project right away. Response is returned before the sort runs; use `/healthz` + container logs to observe progress.",
        "operationId": "trigger_sort_projects__pid__sort_post",
        "parameters": [
          {
            "name": "pid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "title": "Pid"
            }
          },
          {
