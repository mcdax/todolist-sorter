      "get": {
        "tags": [
          "providers"
        ],
        "summary": "List remote provider-side projects",
        "description": "Calls the provider's API (e.g. Todoist) to enumerate every project the configured credentials can access. Used by the CLI's interactive `projects create` picker so users don't have to copy the numeric project id by hand.",
        "operationId": "list_remote_projects_providers__provider__projects_get",
        "parameters": [
          {
            "name": "provider",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Provider"
