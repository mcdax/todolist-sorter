    "/webhook/{provider}": {
      "post": {
        "tags": [
          "webhook"
        ],
        "summary": "Provider webhook receiver",
        "description": "Receives webhook events from a task provider (currently `todoist`). Verifies the provider-specific signature (`X-Todoist-Hmac-SHA256` for Todoist), parses the event body, and either schedules a sort (via the debouncer) or drops the event with status `ignored` / `suppressed`. Always responds 200 with a JSON `{status: ...}` body so the provider will not retry.",
        "operationId": "receive_webhook__provider__post",
        "parameters": [
          {
            "name": "provider",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Provider"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Event accepted. `queued` = sort scheduled; `ignored` = unknown project / no project id in payload; `suppressed` = echo of an item the service just wrote to itself.",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "400": {
            "description": "Invalid JSON body."
          },
          "401": {
            "description": "Signature verification failed."
          },
          "404": {
            "description": "Unknown provider id in URL path."
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
